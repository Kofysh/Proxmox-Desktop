<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12</LangVersion>
    <UseWinUI>true</UseWinUI>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;arm64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <RootNamespace>ProxmoxDesktop.App</RootNamespace>
    <AssemblyName>ProxmoxDesktop</AssemblyName>
    <AssemblyVersion>2.0.0.0</AssemblyVersion>
    <!-- La version est lue depuis l'assembly — plus de hardcode dans Program.cs -->
    <InformationalVersion>2.0.0</InformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- WinUI 3 -->
    <PackageReference Include="Microsoft.WindowsAppSDK"             Version="1.5.240802000" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools"    Version="10.0.22621.756" />
    <PackageReference Include="WinUIEx"                            Version="2.4.0" />

    <!-- WebView2 pour les consoles NoVNC / xTermJS -->
    <PackageReference Include="Microsoft.Web.WebView2"             Version="1.0.2849.39" />

    <!-- MVVM Toolkit -->
    <PackageReference Include="CommunityToolkit.Mvvm"               Version="8.3.2" />

    <!-- Référence au projet Core -->
    <ProjectReference Include="..\ProxmoxDesktop.Core\ProxmoxDesktop.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
