<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ProxmoxDesktop.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ProxmoxDesktop.App.Controls"
    xmlns:models="using:ProxmoxDesktop.Core.Api.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Barre de titre -->
        <Grid Grid.Row="0" Background="{ThemeResource NavigationViewDefaultPaneBackground}"
              Padding="16,8" ColumnDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- Logo + titre -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Image Source="/Assets/proxmox.png" Width="24" Height="24"/>
                <TextBlock Text="Proxmox Desktop" Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Recherche -->
            <AutoSuggestBox Grid.Column="1" Margin="24,0"
                            PlaceholderText="Rechercher une VM, un container..."
                            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QueryIcon="Find" MaxWidth="400"/>

            <!-- Refresh -->
            <Button Grid.Column="2" Margin="0,0,8,0"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    ToolTipService.ToolTip="Rafraîchir">
                <FontIcon Glyph="&#xE72C;" FontSize="16"/>
            </Button>

            <!-- ProgressRing -->
            <ProgressRing Grid.Column="3" Margin="0,0,8,0"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="20" Height="20"/>

            <!-- Déconnexion -->
            <Button Grid.Column="4"
                    Command="{x:Bind ViewModel.LogoutCommand}"
                    ToolTipService.ToolTip="Déconnexion">
                <FontIcon Glyph="&#xF3B1;" FontSize="16"/>
            </Button>
        </Grid>

        <!-- Message de statut / erreur -->
        <InfoBar Grid.Row="1"
                 IsOpen="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource NotNullToBoolConverter}}"
                 Severity="Error"
                 Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                 IsClosable="True"/>

        <!-- Grille de machines -->
        <ScrollViewer Grid.Row="2" Padding="16">
            <ItemsView x:Name="MachineGrid"
                       ItemsSource="{x:Bind ViewModel.FilteredMachines, Mode=OneWay}"
                       SelectionMode="None">
                <ItemsView.Layout>
                    <UniformGridLayout
                        MinItemWidth="180"
                        MinItemHeight="200"
                        ItemsStretch="Fill"
                        MinColumnSpacing="12"
                        MinRowSpacing="12"/>
                </ItemsView.Layout>
                <ItemsView.ItemTemplate>
                    <DataTemplate x:DataType="models:MachineData">
                        <controls:MachineCard Machine="{x:Bind}"/>
                    </DataTemplate>
                </ItemsView.ItemTemplate>
            </ItemsView>
        </ScrollViewer>
    </Grid>
</Page>
