<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ProxmoxDesktop.App.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
          Width="400" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo + titre -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,16">
            <Image Source="/Assets/proxmox.png" Width="64" Height="64"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Proxmox Desktop" Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Serveur -->
        <TextBox Grid.Row="1"
                 Header="Adresse du serveur"
                 PlaceholderText="192.168.1.10"
                 Text="{x:Bind ViewModel.Server, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="Server_LostFocus"/>

        <!-- Port -->
        <TextBox Grid.Row="2"
                 Header="Port"
                 PlaceholderText="8006"
                 Text="{x:Bind ViewModel.Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="Server_LostFocus"/>

        <!-- Realm -->
        <ComboBox Grid.Row="3"
                  Header="Realm"
                  HorizontalAlignment="Stretch"
                  ItemsSource="{x:Bind ViewModel.Realms, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedRealm, Mode=TwoWay}"
                  DisplayMemberPath="Realm"
                  PlaceholderText="Chargement..."/>

        <!-- Utilisateur -->
        <TextBox Grid.Row="4"
                 Header="Utilisateur"
                 PlaceholderText="root"
                 Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Mot de passe -->
        <PasswordBox Grid.Row="5"
                     Header="Mot de passe"
                     Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- TOTP (visible uniquement si requis) -->
        <TextBox Grid.Row="6"
                 Header="Code TOTP"
                 PlaceholderText="123456"
                 Text="{x:Bind ViewModel.Otp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Visibility="{x:Bind ViewModel.TotpVisible, Mode=OneWay}"/>

        <!-- Skip SSL -->
        <CheckBox Grid.Row="7"
                  Content="Ignorer la vérification SSL"
                  IsChecked="{x:Bind ViewModel.SkipSsl, Mode=TwoWay}"/>

        <!-- Message d'erreur -->
        <InfoBar Grid.Row="8"
                 IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NotNullToBoolConverter}}"
                 Severity="Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 IsClosable="False"
                 Margin="0,4,0,0"/>

        <!-- Bouton connexion -->
        <Button Grid.Row="8"
                Content="Se connecter"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.LoginCommand}"
                Margin="0,8,0,0">
            <Button.Content>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                  Width="16" Height="16"
                                  Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"/>
                    <TextBlock Text="Se connecter"/>
                </StackPanel>
            </Button.Content>
        </Button>
    </Grid>
</Page>
