<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ProxmoxDesktop.App.Views.ConsolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="using:Microsoft.Web.WebView2.Core"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,*">

        <!-- Barre d'outils -->
        <Grid Grid.Row="0" Padding="8,4" ColumnDefinitions="Auto,*,Auto"
              Background="{ThemeResource NavigationViewDefaultPaneBackground}">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Image Source="/Assets/proxmox.png" Width="18" Height="18"/>
                <TextBlock x:ConnectionId='4' x:Name="ConsoleTitleBlock" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>

            <Button x:ConnectionId='3' Grid.Column="2"
                                        
                    ToolTipService.ToolTip="Recharger la console">
                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- WebView2 pour NoVNC / xTermJS -->
        <WebView2 x:ConnectionId='2' x:Name="ConsoleWebView"
                  Grid.Row="1"
                                                                 
                                                                   />
    </Grid>
</Page>

