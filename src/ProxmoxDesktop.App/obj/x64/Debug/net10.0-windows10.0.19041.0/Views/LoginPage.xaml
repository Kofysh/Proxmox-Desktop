<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ProxmoxDesktop.App.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
          Width="400" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo + titre -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,16">
            <Image Source="/Assets/proxmox.png" Width="64" Height="64"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Proxmox Desktop" Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Serveur -->
        <TextBox x:ConnectionId='2' Grid.Row="1"
                 Header="Adresse du serveur"
                 PlaceholderText="192.168.1.10"
                                                                                                   
                                             />

        <!-- Port -->
        <TextBox x:ConnectionId='3' Grid.Row="2"
                 Header="Port"
                 PlaceholderText="8006"
                                                                                                 
                                             />

        <!-- Realm -->
        <ComboBox x:ConnectionId='4' Grid.Row="3"
                  Header="Realm"
                  HorizontalAlignment="Stretch"
                                                                      
                                                                              
                  DisplayMemberPath="Realm"
                  PlaceholderText="Chargement..."/>

        <!-- Utilisateur -->
        <TextBox x:ConnectionId='5' Grid.Row="4"
                 Header="Utilisateur"
                 PlaceholderText="root"
                                                                                                     />

        <!-- Mot de passe -->
        <PasswordBox x:ConnectionId='6' Grid.Row="5"
                     Header="Mot de passe"
                                                                                                             />

        <!-- TOTP (visible uniquement si requis) -->
        <TextBox x:ConnectionId='7' Grid.Row="6"
                 Header="Code TOTP"
                 PlaceholderText="123456"
                                                                                                
                                                                         />

        <!-- Skip SSL -->
        <CheckBox x:ConnectionId='8' Grid.Row="7"
                  Content="Ignorer la vérification SSL"
                                                                     />

        <!-- Message d'erreur -->
        <InfoBar x:ConnectionId='9' Grid.Row="8"
                                                                                                                         
                 Severity="Error"
                                                                       
                 IsClosable="False"
                 Margin="0,4,0,0"/>

        <!-- Bouton connexion -->
        <Button x:ConnectionId='10' Grid.Row="9"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}"
                                                         
                Margin="0,8,0,0">
            <Button.Content>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ProgressRing x:ConnectionId='11'                                                  
                                  Width="16" Height="16"
                                                                                     />
                    <TextBlock Text="Se connecter"/>
                </StackPanel>
            </Button.Content>
        </Button>
    </Grid>
</Page>

