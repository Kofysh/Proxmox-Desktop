<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ProxmoxDesktop.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ProxmoxDesktop.App.Controls"
    xmlns:models="using:ProxmoxDesktop.Core.Api.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Barre de titre -->
        <Grid Grid.Row="0" Background="{ThemeResource NavigationViewDefaultPaneBackground}"
              Padding="16,8" ColumnDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- Logo + titre -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Image Source="/Assets/proxmox.png" Width="24" Height="24"/>
                <TextBlock Text="Proxmox Desktop" Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Recherche -->
            <AutoSuggestBox x:ConnectionId='6' Grid.Column="1" Margin="24,0"
                            PlaceholderText="Rechercher une VM, un container..."
                                                                                                                   
                            QueryIcon="Find" MaxWidth="400"/>

            <!-- Refresh -->
            <Button x:ConnectionId='7' Grid.Column="2" Margin="0,0,8,0"
                                                               
                    ToolTipService.ToolTip="Rafraîchir">
                <FontIcon Glyph="&#xE72C;" FontSize="16"/>
            </Button>

            <!-- ProgressRing -->
            <ProgressRing x:ConnectionId='8' Grid.Column="3" Margin="0,0,8,0"
                                                                              
                          Width="20" Height="20"/>

            <!-- Déconnexion -->
            <Button x:ConnectionId='9' Grid.Column="4"
                                                              
                    ToolTipService.ToolTip="Déconnexion">
                <FontIcon Glyph="&#xF3B1;" FontSize="16"/>
            </Button>
        </Grid>

        <!-- Message de statut / erreur -->
        <InfoBar x:ConnectionId='2' Grid.Row="1"
                                                                                                                          
                 Severity="Error"
                                                                        
                 IsClosable="True"/>

        <!-- Grille de machines -->
        <ScrollViewer Grid.Row="2" Padding="16">
            <ItemsView x:ConnectionId='3' x:Name="MachineGrid"
                                                                                     
                       SelectionMode="None">
                <ItemsView.Layout>
                    <UniformGridLayout
                        MinItemWidth="180"
                        MinItemHeight="200"
                        ItemsStretch="Fill"
                        MinColumnSpacing="12"
                        MinRowSpacing="12"/>
                </ItemsView.Layout>
                <ItemsView.ItemTemplate>
                    <DataTemplate                                >
                        <controls:MachineCard x:ConnectionId='5'                   />
                    </DataTemplate>
                </ItemsView.ItemTemplate>
            </ItemsView>
        </ScrollViewer>
    </Grid>
</Page>

