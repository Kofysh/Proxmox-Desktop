<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ProxmoxDesktop.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="420" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo + title -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,16">
            <Image Source="/Assets/proxmox.png" Width="64" Height="64" HorizontalAlignment="Center"/>
            <TextBlock Text="Proxmox Desktop" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Server + Port -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" Header="Server address" PlaceholderText="192.168.1.10"
                     Text="{x:Bind ViewModel.Server, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     LostFocus="Server_LostFocus"/>
            <TextBox Grid.Column="1" Header="Port" PlaceholderText="8006" Width="90"
                     Text="{x:Bind ViewModel.Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     LostFocus="Server_LostFocus"/>
        </Grid>

        <!-- Auth mode selector -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="4">
            <RadioButton Content="Password" GroupName="AuthMode" FontSize="13"
                         IsChecked="{x:Bind ViewModel.UseApiToken, Mode=TwoWay, Converter={StaticResource BoolToInverseVisibilityConverter}}"
                         Padding="12,6"/>
            <RadioButton Content="API Token" GroupName="AuthMode" FontSize="13"
                         IsChecked="{x:Bind ViewModel.UseApiToken, Mode=TwoWay}"
                         Padding="12,6"/>
        </StackPanel>

        <!-- Password form -->
        <StackPanel Grid.Row="3" Spacing="12"
                    Visibility="{x:Bind ViewModel.UseApiToken, Mode=OneWay, Converter={StaticResource BoolToInverseVisibilityConverter}}">
            <ComboBox Header="Realm" HorizontalAlignment="Stretch"
                      ItemsSource="{x:Bind ViewModel.Realms, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedRealm, Mode=TwoWay}"
                      DisplayMemberPath="Realm" PlaceholderText="Loading..."/>
            <TextBox Header="Username" PlaceholderText="root"
                     Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <PasswordBox Header="Password"
                         Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Header="TOTP code" PlaceholderText="123456"
                     Text="{x:Bind ViewModel.Otp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{x:Bind ViewModel.TotpVisible, Mode=OneWay}"/>
        </StackPanel>

        <!-- API Token form -->
        <StackPanel Grid.Row="3" Spacing="12"
                    Visibility="{x:Bind ViewModel.UseApiToken, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBox Header="Token ID" PlaceholderText="root@pam!mytoken"
                     Text="{x:Bind ViewModel.TokenId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <PasswordBox Header="Token Secret" Password="{x:Bind ViewModel.TokenSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"/>
            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap">
                Create a token in Proxmox UI → Datacenter → Permissions → API Tokens.
                Token ID is saved, secret is never stored.
            </TextBlock>
        </StackPanel>

        <!-- SSL + Error -->
        <StackPanel Grid.Row="4" Spacing="8">
            <CheckBox Content="Ignore SSL certificate" IsChecked="{x:Bind ViewModel.SkipSsl, Mode=TwoWay}"/>
            <InfoBar IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NotNullToBoolConverter}}"
                     Severity="Error" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="False"/>
        </StackPanel>

        <!-- Connect button -->
        <Button Grid.Row="5" HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.LoginCommand}" Margin="0,4,0,0">
            <Button.Content>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="16" Height="16"
                                  Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"/>
                    <TextBlock Text="Connect"/>
                </StackPanel>
            </Button.Content>
        </Button>
    </Grid>
</Page>
