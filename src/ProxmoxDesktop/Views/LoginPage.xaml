<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ProxmoxDesktop.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,16">
            <Image Source="/Assets/proxmox.png" Width="64" Height="64" HorizontalAlignment="Center"/>
            <TextBlock Text="Proxmox Desktop" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center"/>
        </StackPanel>

        <TextBox Grid.Row="1" Header="Server address" PlaceholderText="192.168.1.10"
                 Text="{x:Bind ViewModel.Server, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="Server_LostFocus"/>

        <TextBox Grid.Row="2" Header="Port" PlaceholderText="8006"
                 Text="{x:Bind ViewModel.Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="Server_LostFocus"/>

        <ComboBox Grid.Row="3" Header="Realm" HorizontalAlignment="Stretch"
                  ItemsSource="{x:Bind ViewModel.Realms, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedRealm, Mode=TwoWay}"
                  DisplayMemberPath="Realm" PlaceholderText="Loading..."/>

        <TextBox Grid.Row="4" Header="Username" PlaceholderText="root"
                 Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <PasswordBox Grid.Row="5" Header="Password"
                     Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBox Grid.Row="6" Header="TOTP code" PlaceholderText="123456"
                 Text="{x:Bind ViewModel.Otp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Visibility="{x:Bind ViewModel.TotpVisible, Mode=OneWay}"/>

        <CheckBox Grid.Row="7" Content="Ignore SSL certificate"
                  IsChecked="{x:Bind ViewModel.SkipSsl, Mode=TwoWay}"/>

        <InfoBar Grid.Row="8"
                 IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NotNullToBoolConverter}}"
                 Severity="Error" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 IsClosable="False" Margin="0,4,0,0"/>

        <Button Grid.Row="9" HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.LoginCommand}" Margin="0,8,0,0">
            <Button.Content>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="16" Height="16"
                                  Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"/>
                    <TextBlock Text="Connect"/>
                </StackPanel>
            </Button.Content>
        </Button>
    </Grid>
</Page>
