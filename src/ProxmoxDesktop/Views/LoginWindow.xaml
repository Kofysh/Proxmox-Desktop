<Window
    x:Class="ProxmoxDesktop.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:ProxmoxDesktop.ViewModels"
    xmlns:converters="clr-namespace:ProxmoxDesktop.Converters"
    Title="Proxmox Desktop"
    Width="440" SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="{DynamicResource MaterialDesign.Brush.Background}"
    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
    FontFamily="{md:MaterialDesignFont}"
    md:ThemeAssist.Theme="Inherit">

    <Window.Resources>
        <converters:NotNullToVisibilityConverter     x:Key="NotNullToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <BooleanToVisibilityConverter               x:Key="BoolToVisibility"/>
    </Window.Resources>

    <md:DialogHost Identifier="LoginDialog">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,32,40,40" Width="360">

                <!-- Logo + title -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                    <Image Source="/Assets/proxmox.png" Width="72" Height="72"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Proxmox Desktop"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                               HorizontalAlignment="Center" FontWeight="Medium"/>
                    <TextBlock Text="Connect to your Proxmox VE server"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               HorizontalAlignment="Center" Opacity="0.6" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Server row -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             md:HintAssist.Hint="Server address"
                             md:HintAssist.FloatingScale="0.85"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                             LostFocus="Server_LostFocus"/>
                    <TextBox Grid.Column="2"
                             md:HintAssist.Hint="Port"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             LostFocus="Server_LostFocus"/>
                </Grid>

                <!-- Auth mode tabs -->
                <TabControl Margin="0,8,0,16"
                            Style="{StaticResource MaterialDesignTabControl}"
                            SelectedIndex="{Binding UseApiToken, Converter={StaticResource BoolToVisibility}}">

                    <!-- Password tab -->
                    <TabItem Header="PASSWORD">
                        <StackPanel Margin="0,16,0,0" Spacing="12">
                            <ComboBox
                                md:HintAssist.Hint="Realm"
                                Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                ItemsSource="{Binding Realms}"
                                SelectedItem="{Binding SelectedRealm}"
                                DisplayMemberPath="Realm"
                                Visibility="{Binding Realms.Count, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBox
                                md:HintAssist.Hint="Username"
                                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                            <PasswordBox
                                x:Name="PasswordBox"
                                md:HintAssist.Hint="Password"
                                Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                md:TextFieldAssist.HasClearButton="False"
                                PasswordChanged="PasswordBox_PasswordChanged"/>
                            <TextBox
                                md:HintAssist.Hint="TOTP code"
                                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                Text="{Binding Otp, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding TotpVisible, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </TabItem>

                    <!-- API Token tab -->
                    <TabItem Header="API TOKEN">
                        <StackPanel Margin="0,16,0,0" Spacing="12">
                            <TextBox
                                md:HintAssist.Hint="Token ID (user@realm!tokenid)"
                                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                Text="{Binding TokenId, UpdateSourceTrigger=PropertyChanged}"/>
                            <PasswordBox
                                x:Name="TokenSecretBox"
                                md:HintAssist.Hint="Token Secret"
                                Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                PasswordChanged="TokenSecretBox_PasswordChanged"/>
                            <TextBlock
                                Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                TextWrapping="Wrap" Opacity="0.6"
                                Text="Create tokens in Proxmox: Datacenter → Permissions → API Tokens. Secret is never saved."/>
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <!-- SSL toggle -->
                <CheckBox Content="Ignore SSL certificate"
                          IsChecked="{Binding SkipSsl}"
                          Margin="0,0,0,16"
                          Style="{StaticResource MaterialDesignCheckBox}"/>

                <!-- Error message -->
                <md:Card
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToVisibility}}"
                    Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                    Padding="12,8" Margin="0,0,0,16" UniformCornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <md:PackIcon Kind="AlertCircleOutline" VerticalAlignment="Center"
                                     Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </md:Card>

                <!-- Connect button -->
                <Button
                    Content="CONNECT"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    md:ButtonAssist.CornerRadius="8"
                    HorizontalAlignment="Stretch"
                    Height="44"
                    IsDefault="True">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <md:PackIcon Kind="Connection" VerticalAlignment="Center"
                                         Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}"/>
                            <ProgressBar
                                Style="{StaticResource MaterialDesignCircularProgressBar}"
                                Value="0" IsIndeterminate="True" Width="18" Height="18"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="CONNECT" VerticalAlignment="Center" FontWeight="Medium"
                                       Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}"/>
                            <TextBlock Text="Connecting..." VerticalAlignment="Center" FontWeight="Medium"
                                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </md:DialogHost>
</Window>
