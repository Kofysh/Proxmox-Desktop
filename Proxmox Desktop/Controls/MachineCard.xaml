<UserControl
    x:Class="ProxmoxDesktop.Controls.MachineCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:converters="clr-namespace:ProxmoxDesktop.Converters">
    <UserControl.Resources>
        <converters:StatusToBrushConverter           x:Key="StatusToBrush"/>
        <converters:BytesToReadableConverter         x:Key="BytesToReadable"/>
        <converters:CpuPercentConverter              x:Key="CpuPercent"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:CollectionToVisibilityConverter  x:Key="CollectionToVisibility"/>
        <BooleanToVisibilityConverter                x:Key="BoolToVisibility"/>
        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconForegroundButton}">
            <Setter Property="Width"   Value="32"/>
            <Setter Property="Height"  Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="md:ButtonAssist.CornerRadius" Value="16"/>
        </Style>
    </UserControl.Resources>

    <md:Card Width="220" UniformCornerRadius="12" md:ElevationAssist.Elevation="Dp3" Cursor="Hand">
        <md:Card.ContextMenu>
            <ContextMenu>
                <MenuItem Header="NoVNC"      Command="{Binding OpenNoVncCommand,   RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=MonitorEye}"/>
                <MenuItem Header="xTermJS"    Command="{Binding OpenXtermCommand,   RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Console}"/>
                <MenuItem Header="SPICE"      Command="{Binding OpenSpiceCommand,   RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Desktopclassic}"/>
                <Separator/>
                <MenuItem Header="Start"      Command="{Binding StartCommand,       RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Play}"/>
                <MenuItem Header="Shutdown"   Command="{Binding ShutdownCommand,   RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Power}"/>
                <MenuItem Header="Reboot"     Command="{Binding RebootCommand,     RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Restart}"/>
                <MenuItem Header="Suspend"    Command="{Binding SuspendCommand,    RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Pause}"/>
                <MenuItem Header="Resume"     Command="{Binding ResumeCommand,     RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Play}"/>
                <MenuItem Header="Hibernate"  Command="{Binding HibernateCommand,  RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Snowflake}"/>
                <MenuItem Header="Force Stop" Command="{Binding StopCommand,       RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Stop}"/>
                <MenuItem Header="Reset"      Command="{Binding ResetCommand,      RelativeSource={RelativeSource AncestorType=UserControl}}" Icon="{md:PackIcon Kind=Autorenew}"/>
            </ContextMenu>
        </md:Card.ContextMenu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Status color bar -->
            <Border Grid.Row="0" Height="5" CornerRadius="12,12,0,0"
                    Background="{Binding Machine.Status, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StatusToBrush}}"/>

            <!-- Main content -->
            <StackPanel Grid.Row="1" Margin="14,12,14,8">

                <!-- Type badge + VMID -->
                <DockPanel Margin="0,0,0,10">
                    <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="{Binding Machine.Type, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    </Border>
                    <TextBlock Text="{Binding Machine.Vmid, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='#{0}'}"
                               DockPanel.Dock="Right"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.45" VerticalAlignment="Center" FontWeight="Medium"/>
                </DockPanel>

                <!-- Icon -->
                <Image Source="{Binding MachineIcon, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Width="52" Height="52" HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,10"/>

                <!-- VM Name -->
                <TextBlock Text="{Binding Machine.Name, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                           TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,6"/>

                <!-- Status chip -->
                <Border HorizontalAlignment="Center" CornerRadius="10" Margin="0,0,0,12"
                        Background="{Binding Machine.Status, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StatusToBrush}}"
                        Padding="10,3">
                    <TextBlock Text="{Binding Machine.Status, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontSize="10" FontWeight="Bold" Foreground="White"/>
                </Border>

                <!-- Tags (click to filter) -->
                <ItemsControl ItemsSource="{Binding Machine.TagList, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              Visibility="{Binding Machine.TagList, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource CollectionToVisibility}}"
                              HorizontalAlignment="Center" Margin="0,0,0,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel HorizontalAlignment="Center"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding FilterTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Padding="6,0" Height="20" MinWidth="0" Margin="2,0"
                                    md:ButtonAssist.CornerRadius="10" ToolTip="Filter by this tag">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Tag" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding}" FontSize="10"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- CPU bar -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CPU" FontSize="10" FontWeight="Medium" Opacity="0.5" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="1"
                                 Value="{Binding Machine.CpuPercent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Maximum="100" Height="6"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" FontSize="10" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Text="{Binding Machine.Cpu, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource CpuPercent}}"/>
                </Grid>

                <!-- RAM bar -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="RAM" FontSize="10" FontWeight="Medium" Opacity="0.5" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="1"
                                 Value="{Binding Machine.MemPercent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Maximum="100" Height="6"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" FontSize="10" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Text="{Binding Machine.Mem, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BytesToReadable}}"/>
                </Grid>
            </StackPanel>

            <!-- Quick action buttons -->
            <Border Grid.Row="2" Background="{DynamicResource MaterialDesign.Brush.CardBackground}" Padding="8,6"
                    BorderThickness="0,1,0,0" BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource ActionBtn}" ToolTip="NoVNC Console"
                            Command="{Binding OpenNoVncCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <md:PackIcon Kind="MonitorEye" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource ActionBtn}" ToolTip="xTermJS"
                            Command="{Binding OpenXtermCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <md:PackIcon Kind="Console" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource ActionBtn}" ToolTip="Start"
                            Command="{Binding StartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Visibility="{Binding Machine.IsRunning, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVisibility}}">
                        <md:PackIcon Kind="Play" Width="16" Height="16" Foreground="#4CAF50"/>
                    </Button>
                    <Button Style="{StaticResource ActionBtn}" ToolTip="Shutdown"
                            Command="{Binding ShutdownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Visibility="{Binding Machine.IsRunning, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                        <md:PackIcon Kind="Power" Width="16" Height="16" Foreground="#F44336"/>
                    </Button>
                    <Button Style="{StaticResource ActionBtn}" ToolTip="Reboot"
                            Command="{Binding RebootCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Visibility="{Binding Machine.IsRunning, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                        <md:PackIcon Kind="Restart" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Node footer -->
            <Border Grid.Row="3"
                    Background="{Binding Machine.Status, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StatusToBrush}}"
                    Padding="8,5" CornerRadius="0,0,12,12" Opacity="0.85">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <md:PackIcon Kind="Server" Width="12" Height="12" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding Machine.NodeName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontSize="10" FontWeight="Medium" HorizontalAlignment="Center" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </md:Card>
</UserControl>
