<UserControl
    x:Class="ProxmoxDesktop.Controls.StatsBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Border Background="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}" Padding="16,10"
            BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

            <!-- Total VMs -->
            <Border CornerRadius="8" Background="{DynamicResource MaterialDesign.Brush.Primary}" Padding="14,8" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Server" Width="18" Height="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding TotalCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="18" FontWeight="Bold" Foreground="White" LineHeight="20"/>
                        <TextBlock Text="Total" FontSize="10" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Running -->
            <Border CornerRadius="8" Background="#4CAF50" Padding="14,8" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Play" Width="18" Height="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding RunningCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="18" FontWeight="Bold" Foreground="White" LineHeight="20"/>
                        <TextBlock Text="Running" FontSize="10" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Stopped -->
            <Border CornerRadius="8" Background="#F44336" Padding="14,8" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Stop" Width="18" Height="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding StoppedCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="18" FontWeight="Bold" Foreground="White" LineHeight="20"/>
                        <TextBlock Text="Stopped" FontSize="10" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- VMs -->
            <Border CornerRadius="8" Background="{DynamicResource MaterialDesign.Brush.Secondary}" Padding="14,8" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Monitor" Width="18" Height="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding VmCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="18" FontWeight="Bold" Foreground="White" LineHeight="20"/>
                        <TextBlock Text="VMs" FontSize="10" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- LXC -->
            <Border CornerRadius="8" Background="#FF9800" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Cube" Width="18" Height="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding LxcCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="18" FontWeight="Bold" Foreground="White" LineHeight="20"/>
                        <TextBlock Text="LXC" FontSize="10" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</UserControl>
